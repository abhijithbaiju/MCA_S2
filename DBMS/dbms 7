    -> BEGIN
    ->     DECLARE reversed INT DEFAULT 0;
    ->     DECLARE remainder INT;
    ->     DECLARE temp INT;
    -> 
    ->     SET temp = num;
    -> 
    ->     WHILE temp > 0 DO
    ->         SET remainder = temp % 10;
    ->         SET reversed = (reversed * 10) + remainder;
    ->         SET temp = FLOOR(temp / 10);
    ->     END WHILE;
    -> 
