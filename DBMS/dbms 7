    ->     IF current_balance IS NULL THEN
    ->         SELECT 'Account does not exist' AS message;
    -> 
    ->     ELSEIF current_balance - amount >= 1000 THEN
    ->         UPDATE accounts
    ->         SET balance = balance - amount
    ->         WHERE acc_id = accnt_id;
    -> 
    ->         SELECT 'Withdrawal successful' AS message;
    -> 
